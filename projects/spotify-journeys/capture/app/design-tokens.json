{
    "colors": {
        "background": {
            "base": "#121212",
            "highlight": "#1a1a1a",
            "press": "#000000",
            "elevated": "#242424",
            "card": "#181818",
            "card-hover": "#282828"
        },
        "text": {
            "base": "#ffffff",
            "subdued": "#b3b3b3",
            "bright": "#ffffff",
            "negative": "#ff4136"
        },
        "primary": {
            "base": "#1ed760",
            "hover": "#1fdf64",
            "active": "#169c46"
        }
    },
    "typography": {
        "fontFamily": "CircularSp, CircularSp-Arab, CircularSp-Hebr, CircularSp-Cyrl, CircularSp-Grek, CircularSp-Deva, sans-serif",
        "sizes": {
